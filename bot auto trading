        logging.error("Failed to initialize MT5")
        return

    logging.info(f"[{get_server_time_str()}] AUTONOMOUS ENGINE LOADED - {SYMBOL}")
    print(f"[{get_server_time_str()}] AUTONOMOUS ENGINE LOADED - {SYMBOL}", flush=True)
    next_run = time.time()

    while True:
        current_time = time.time()
        if current_time >= next_run:
            try:
                next_run = current_time + CHECK_INTERVAL
                market_data, live_price = get_market_data_full()
                if not market_data:
                    logging.warning("Failed to get market data, skipping this cycle")
                    continue

                pos = mt5.positions_get(symbol=SYMBOL)
                current_pos = None
                if pos:
                    p = pos[0]
                    current_pos = {"ticket": p.ticket, "type": "BUY" if p.type == 0 else "SELL", "sl": p.sl, "tp": p.tp, "profit": round(p.profit, 2)}
                    opsi_aksi = "MODIFY, CLOSE, HOLD, COUNTER"
                else:
                    opsi_aksi = "OPEN, WAIT"

                # PROMPT UNBURDENED (Broad Thinking)
                prompt = f"""
                You are an unburdened, high-level financial strategist.
                Your task is to manage trading decisions for {SYMBOL} with absolute autonomy.
                Use your entire analytical knowledge base to interpret the provided data.

                MARKET DATA:
                - Current Price: {live_price}
                - Historical Context: {json.dumps(market_data)}
                - Your Current Position: {json.dumps(current_pos)}

                GOAL:
                Analyze the narrative across all timeframes. Decide the most logical next step to maximize profit and minimize risk.
                - If no position: Decide to OPEN or WAIT.
                - If position active: Decide to MODIFY, CLOSE, HOLD, or COUNTER.

                CONSTRAINT: Output JSON only. No explanation.
                {{ "action": "{opsi_aksi}", "type": "BUY/SELL/NONE", "sl": 0.0, "tp": 0.0 }}
                """

                response = client.models.generate_content(model=MODEL_NAME, contents=prompt)
                res_text = response.text.strip()

                # Extract JSON from response
                if "{" in res_text:
                    res_text = res_text[res_text.find("{"):res_text.rfind("}")+1]

                # Parse JSON
                try:
                    decision = json.loads(res_text)
                except json.JSONDecodeError as e:
                    logging.error(f"Failed to parse AI response as JSON: {e}")
                    logging.error(f"AI response: {res_text}")
                    continue

                # Debugging (Overwrite)
                with open("debug_prompt_ai.txt", mode="w", encoding="utf-8") as f:
                    f.write(prompt)

                # Validate AI response before execution
                if not validate_ai_response(decision, current_pos, live_price):
                    logging.error("AI response validation failed, skipping execution")
                    send_telegram(f"⚠️ *Validation Failed*\nAI decision rejected: {json.dumps(decision)}")
                    continue

                action = str(decision.get("action")).upper()
                side = str(decision.get("type")).upper()
                sl_p, tp_p = float(decision.get("sl", 0)), float(decision.get("tp", 0))

                # Telegram & Log
                send_telegram(f"🌐 *{SYMBOL} AUTONOMOUS*\nAction: {action}\nSide: {side}\nSL: {sl_p} | TP: {tp_p}")
                add_summary_log(action, side, sl_p, tp_p)

                # Execute actions based on validation
                if not current_pos:
                    if action == "OPEN" and side in ["BUY", "SELL"]:
                        execute_open(side, sl_p, tp_p)
                else:
                    if action == "CLOSE":
                        execute_close(current_pos['ticket'])
                    elif action == "MODIFY":
                        execute_modify(current_pos['ticket'], sl_p, tp_p)
                    elif action == "COUNTER":
                        if execute_close(current_pos['ticket']):
                            time.sleep(1)  # Wait a bit before opening counter position
                            execute_open("SELL" if current_pos['type'] == "BUY" else "BUY", sl_p, tp_p)

            except json.JSONDecodeError as e:
                logging.error(f"JSON parsing error: {e}")
            except Exception as e:
                logging.error(f"Unexpected error in main loop: {e}", exc_info=True)
        time.sleep(1)

if __name__ == "__main__": analyze_and_trade()
