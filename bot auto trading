def execute_open(side, sl, tp):
    try:
        tick = mt5.symbol_info_tick(SYMBOL)
        if not tick:
            logging.error("Failed to get tick data for opening position")
            return False

        m_type = mt5.ORDER_TYPE_BUY if side == "BUY" else mt5.ORDER_TYPE_SELL
        price = tick.ask if m_type == mt5.ORDER_TYPE_BUY else tick.bid
        request = {
            "action": mt5.TRADE_ACTION_DEAL,
            "symbol": SYMBOL,
            "volume": LOT_SIZE,
            "type": m_type,
            "price": price,
            "sl": sl,
            "tp": tp,
            "magic": 999,
            "comment": "AI Autonomous",
            "type_time": mt5.ORDER_TIME_GTC,
            "type_filling": mt5.ORDER_FILLING_FOK
        }

        result = mt5.order_send(request)
        if result.retcode != mt5.TRADE_RETCODE_DONE:
            logging.error(f"Order OPEN failed: {result.retcode} - {result.comment}")
            send_telegram(f"❌ *Order OPEN Failed*\nSide: {side}\nError: {result.comment}")
            return False

        logging.info(f"Order OPEN success: Ticket={result.order}, Side={side}, SL={sl}, TP={tp}")
        send_telegram(f"✅ *Order OPEN Success*\nTicket: {result.order}\nSide: {side}\nSL: {sl} | TP: {tp}")
        return True
    except Exception as e:
        logging.error(f"Exception in execute_open: {e}")
        return False

