def validate_ai_response(decision, current_pos, live_price):
    """Validate AI response before execution"""
    try:
        # Check required fields
        if not isinstance(decision, dict):
            logging.error("AI response is not a dictionary")
            return False

        action = str(decision.get("action", "")).upper()
        side = str(decision.get("type", "")).upper()
        sl = decision.get("sl", 0)
        tp = decision.get("tp", 0)

        # Validate action
        valid_actions = ["OPEN", "WAIT", "MODIFY", "CLOSE", "HOLD", "COUNTER"]
        if action not in valid_actions:
            logging.error(f"Invalid action: {action}. Must be one of {valid_actions}")
            return False

        # Validate side
        valid_sides = ["BUY", "SELL", "NONE"]
        if side not in valid_sides:
            logging.error(f"Invalid side: {side}. Must be one of {valid_sides}")
            return False

        # Validate SL/TP values
        try:
            sl = float(sl)
            tp = float(tp)
        except (ValueError, TypeError):
            logging.error(f"Invalid SL/TP values: SL={sl}, TP={tp}")
            return False

        # Check SL/TP are reasonable (not negative or zero when required)
        if action in ["OPEN", "MODIFY"]:
            if sl < 0 or tp < 0:
                logging.error(f"Negative SL/TP values: SL={sl}, TP={tp}")
                return False

            # Check SL/TP are not too far from current price (sanity check)
            current_price = (live_price["bid"] + live_price["ask"]) / 2

            if sl > 0:  # Only validate if SL is set
                sl_distance = abs(current_price - sl)
                if sl_distance > current_price * 0.1:  # More than 10% away
                    logging.warning(f"SL too far from current price: {sl_distance} ({sl_distance/current_price*100:.1f}%)")

            if tp > 0:  # Only validate if TP is set
                tp_distance = abs(current_price - tp)
                if tp_distance > current_price * 0.2:  # More than 20% away
                    logging.warning(f"TP too far from current price: {tp_distance} ({tp_distance/current_price*100:.1f}%)")

        # Validate logic: can't OPEN if position exists
        if action == "OPEN" and current_pos:
            logging.error("Cannot OPEN: position already exists")
            return False

        # Validate logic: can't CLOSE/MODIFY/COUNTER if no position
        if action in ["CLOSE", "MODIFY", "COUNTER"] and not current_pos:
            logging.error(f"Cannot {action}: no position exists")
            return False

        logging.info(f"AI response validated: Action={action}, Side={side}, SL={sl}, TP={tp}")
        return True

    except Exception as e:
        logging.error(f"Exception in validate_ai_response: {e}")
        return False

